# PropertyArk Mobile App - Environment Variables Template
# Copy this file to .env and fill in the appropriate values for your environment

# ============================================================================
# API Configuration
# ============================================================================

# Backend API URL
# Development: http://localhost:5001
# Staging: https://staging-api.propertyark.com
# Production: https://propertyark-backend.onrender.com/api
REACT_APP_API_URL=https://propertyark-backend.onrender.com/api

# API request timeout in milliseconds (default: 30000)
REACT_APP_API_TIMEOUT=30000

# ============================================================================
# Authentication Configuration
# ============================================================================

# Authentication endpoints
REACT_APP_AUTH_LOGIN_ENDPOINT=/auth/login
REACT_APP_AUTH_LOGOUT_ENDPOINT=/auth/logout
REACT_APP_AUTH_REFRESH_ENDPOINT=/auth/refresh

# ============================================================================
# Cache Configuration
# ============================================================================

# Cache time-to-live in milliseconds (default: 86400000 = 24 hours)
REACT_APP_CACHE_TTL=86400000

# Maximum cache size in bytes (default: 104857600 = 100MB)
REACT_APP_CACHE_MAX_SIZE=104857600

# ============================================================================
# Build Configuration
# ============================================================================

# Build environment (development, staging, production)
REACT_APP_BUILD_ENV=production

# Application version (should match app.json version)
REACT_APP_VERSION=1.0.0

# ============================================================================
# Security Configuration
# ============================================================================

# Enable certificate pinning for HTTPS (true/false)
REACT_APP_CERTIFICATE_PINNING=true

# Enable secure storage for sensitive data (true/false)
REACT_APP_SECURE_STORAGE=true

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (error, warn, info, debug)
REACT_APP_LOG_LEVEL=info

# Enable console logging (true/false)
REACT_APP_CONSOLE_LOGGING=true

# ============================================================================
# Feature Flags
# ============================================================================

# Enable offline mode (true/false)
REACT_APP_OFFLINE_MODE=true

# Enable debug mode (true/false)
REACT_APP_DEBUG_MODE=false

# ============================================================================
# Build System Configuration
# ============================================================================

# Gradle heap memory (e.g., 4g, 6g)
GRADLE_OPTS=-Xmx4g -XX:MaxPermSize=512m

# Android SDK configuration
ANDROID_SDK_ROOT=/path/to/android/sdk
ANDROID_HOME=/path/to/android/sdk

# Java configuration
JAVA_HOME=/path/to/java/home
