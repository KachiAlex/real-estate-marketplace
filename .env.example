# .env (for React frontend)
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key-here

# .env (for Node scripts)
FIREBASE_API_KEY=your-firebase-api-key-here

# Development environment variables
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000

# Postgres - Local Development
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
# Use port 15432 for the local docker postgres in this repo (change if needed)
DB_PORT=15432
DB_NAME=real_estate_db
DB_REQUIRE_SSL=false              # default to false in development (create a .env file!)
DB_REJECT_UNAUTHORIZED=false
# Local fallback DATABASE_URL
DATABASE_URL_LOCAL=postgresql://postgres:password@localhost:15432/real_estate_db

# Postgres - Production (Neon Database)
# Neon Database URL for Vercel deployment
DATABASE_URL=postgresql://neondb_owner:npg_xUZQWBfyGt79@ep-noisy-resonance-am77s3ty-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT - Production (use strong secrets for production)
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Vercel Configuration
REACT_APP_API_URL=/api
NODE_ENV=production

# Example Firebase keys for frontend (keep if needed)
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_API_KEY=your-firebase-api-key-here
